{
  "name": "with-vite-react",
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.9.5"
  },
  "packageManager": "bun@1.3.10",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "dev:api": "turbo dev --filter=@repo/api",
    "typecheck": "turbo typecheck",
    "dev:web": "turbo dev --filter=@repo/web"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}