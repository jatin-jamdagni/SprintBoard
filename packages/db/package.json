{
  "name": "@repo/db",
  "module": "index.ts",
  "type": "module",
  "private": "true",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "echo 'db: no dev server'",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env run src/migrate.ts",
    "db:seed": "bun --env-file=../../.env run src/seed.ts",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bun-types": "^1.3.11",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}